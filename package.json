{
  "name": "chat-plus-extension",
  "description": "Open-source browser extension for adapter-driven MCP orchestration on AI chat websites.",
  "private": true,
  "version": "0.0.8",
  "type": "module",
  "scripts": {
    "version:sync": "node scripts/sync-version.mjs",
    "version:set": "node scripts/set-version.mjs",
    "release:notes": "node scripts/generate-release-notes.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:chrome": "npm run version:sync && node scripts/build-target.mjs chrome",
    "build:firefox": "npm run version:sync && node scripts/build-target.mjs firefox",
    "build": "npm run clean && npm run typecheck && npm run build:chrome && npm run build:firefox",
    "package:chrome": "node scripts/package-release.mjs chrome",
    "package:firefox": "node scripts/package-release.mjs firefox",
    "release:build:chrome": "npm run clean:release && npm run clean && npm run typecheck && npm run build:chrome && npm run package:chrome",
    "release:build": "npm run build && npm run package:chrome && npm run package:firefox",
    "test": "node --import tsx --test test/**/*.test.ts",
    "dev:prepare": "npm run version:sync && node scripts/copy-static.mjs chrome dist/chrome",
    "dev:ui": "vite build --watch --outDir dist/chrome",
    "dev:runtime:ts": "tsc -p tsconfig.runtime.json --watch --outDir dist/chrome",
    "dev:runtime:content": "node scripts/build-content-scripts.mjs dist/chrome --watch",
    "dev:runtime:bg": "node scripts/build-background.mjs dist/chrome --watch",
    "dev:runtime:sandbox": "node scripts/build-sandbox.mjs dist/chrome --watch",
    "dev:runtime": "concurrently \"npm:dev:runtime:ts\" \"npm:dev:runtime:content\" \"npm:dev:runtime:bg\" \"npm:dev:runtime:sandbox\"",
    "dev": "npm run dev:prepare && concurrently \"npm:dev:ui\" \"npm:dev:runtime\"",
    "clean": "node scripts/clean-output.mjs dist",
    "clean:release": "node scripts/clean-output.mjs release"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@hello-pangea/dnd": "^18.0.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@uiw/react-codemirror": "^4.25.8",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/chrome": "0.1.24",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "6.0.1",
    "concurrently": "9.2.1",
    "esbuild": "^0.27.4",
    "jsdom": "^27.0.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vite": "8.0.0"
  }
}
